# Silmaril Firewall credentials for live replay.
# Copy this file to .env only if your shell tooling loads it; the CLI reads
# regular environment variables and does not load .env files by itself.

SILMARIL_API_KEY=
SILMARIL_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com/<stage>/classify

# Optional tenant-specific URL override. The CLI looks up
# SILMARIL_<TENANT>_<STAGE>_API_URL after --api-url and before SILMARIL_API_URL.
# For example, with --tenant acme --stage prod:
# SILMARIL_ACME_PROD_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com/prod/classify
